{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@web/*": ["web/src/*"],
      "@db/*": ["db/src/*"],
      "@domains/*": ["domains/src/*"],
      "@utils/*": ["utils/src/*"],
      "@web-exports/*": ["web/exports/*"],
      "@db-exports/*": ["db/exports/*"],
      "@domains-exports/*": ["domains/exports/*"],
      "@utils-exports/*": ["utils/exports/*"]
    }
  }
}
