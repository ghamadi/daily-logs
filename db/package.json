{
  "name": "@daily-logs/db",
  "version": "0.0.1",
  "private": true,
  "description": "Database schemas and migration scripts for the project",
  "scripts": {
    "lint:js": "eslint ./src --ext .ts",
    "lint:ts": "tsc --noEmit",
    "lint": "pnpm run lint:js && pnpm run lint:ts",
    "test-connection": "node --env-file=.env --import tsx src/scripts/test-connection.ts",
    "generate": "drizzle-kit generate --config drizzle.config.ts",
    "migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@daily-logs/domain": "workspace:*",
    "@daily-logs/utils": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.18.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
